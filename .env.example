# LLM
AMD_VLLM_BASE_URL=http://localhost:8000/v1

# Database
DATABASE_URL=postgresql://opsscout:password@localhost:5432/opsscout

# Mode — set to false to hit real data providers (cached at mock/cache/)
DEMO_MODE=true

# Real-data providers (used when DEMO_MODE=false)
PHQ_TOKEN=                      # PredictHQ Bearer token (14-day free trial)
# Open-Meteo (weather): no key required for non-commercial use
# @openbnb/mcp-server-airbnb (accommodation): no key required; needs `npx` in PATH

# Production-only (Slice 5+ deferred OAuth flows; leave blank in demo mode)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SLACK_BOT_TOKEN=
